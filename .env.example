# ============================================================
# WhatsApp Chat Dashboard — Environment Variables
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git
# ============================================================

# ----------------------------
# Supabase (required)
# Get these from: https://supabase.com/dashboard → Settings → API
# ----------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ----------------------------
# n8n Webhooks (required for message flow)
# ----------------------------

# Secret token shared between n8n and this dashboard
# Generate a random string: openssl rand -hex 32
N8N_WEBHOOK_SECRET=your-random-secret-here

# n8n webhook URL that receives manual replies from this dashboard
# Format: https://your-n8n-instance.com/webhook/reply-handler
N8N_REPLY_WEBHOOK_URL=https://your-n8n.com/webhook/whatsapp-reply

# ----------------------------
# WhatsApp Cloud API (used by n8n, not directly by this app)
# Kept here for reference — configure these inside n8n workflows
# ----------------------------
# WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
# WHATSAPP_BUSINESS_ACCOUNT_ID=your-business-account-id
# WHATSAPP_ACCESS_TOKEN=your-permanent-access-token

# ----------------------------
# App (optional)
# ----------------------------
NEXTAUTH_URL=http://localhost:3000
